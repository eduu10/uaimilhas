generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

enum Tier {
  BRONZE
  PRATA
  OURO
  DIAMANTE
}

enum TransactionType {
  GANHO
  RESGATE
  BONUS
  AJUSTE
  ASSINATURA
}

enum CourseAccess {
  GRATUITO
  PAGO
  PONTOS
}

enum OrderStatus {
  PENDENTE
  CONFIRMADO
  ENVIADO
  ENTREGUE
  CANCELADO
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           Role      @default(CLIENTE)
  points         Int       @default(0)
  tier           Tier      @default(BRONZE)
  isBlocked      Boolean   @default(false)
  stripeCustomerId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  transactions   PointTransaction[]
  enrollments    Enrollment[]
  orders         Order[]
  tripBookings   TripBooking[]
  subscription   Subscription?
  flightAlerts   FlightAlert[]
  milesListings  MilesListing[] @relation("MilesListingSeller")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PointTransaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Int
  description String
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model PointRule {
  id              String   @id @default(cuid())
  name            String
  description     String
  reaisPerPoint   Float    @default(1)
  multiplier      Float    @default(1)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("point_rules")
}

model BonusCampaign {
  id          String   @id @default(cuid())
  name        String
  description String
  multiplier  Float
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bonus_campaigns")
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  thumbnail   String?
  accessType  CourseAccess  @default(PONTOS)
  pointsCost  Int          @default(0)
  price       Float        @default(0)
  level       String       @default("Iniciante")
  duration    String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  modules     Module[]
  enrollments Enrollment[]

  @@map("courses")
}

model Module {
  id        String   @id @default(cuid())
  courseId   String
  title     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id        String   @id @default(cuid())
  moduleId  String
  title     String
  videoUrl  String?
  content   String?  @db.Text
  duration  String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Enrollment {
  id          String   @id @default(cuid())
  userId      String
  courseId     String
  progress    Float    @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  images      String[]
  pointsCost  Int
  stock       Int      @default(0)
  categoryId  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  orders   Order[]

  @@map("products")
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  productId String
  quantity  Int         @default(1)
  points    Int
  status    OrderStatus @default(PENDENTE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("orders")
}

model Trip {
  id          String   @id @default(cuid())
  destination String
  description String   @db.Text
  images      String[]
  hotel       String?
  airline     String?
  pointsCost  Int
  spots       Int      @default(0)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings TripBooking[]

  @@map("trips")
}

model TripBooking {
  id        String      @id @default(cuid())
  userId    String
  tripId    String
  points    Int
  status    OrderStatus @default(PENDENTE)
  travelDate DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id])

  @@map("trip_bookings")
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  pointsPerMonth Int
  features      String[]
  stripePriceId String?
  isPopular     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  planId             String
  stripeSubscriptionId String?
  status             String   @default("active")
  currentPeriodEnd   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model PlatformSettings {
  id        String   @id @default(cuid())
  name      String   @default("UAI Milhas")
  logo      String?
  primaryColor String @default("#7C3AED")
  secondaryColor String @default("#2563EB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// ==================== ALERTAS DE VOOS ====================

model FlightAlert {
  id            String   @id @default(cuid())
  userId        String
  origin        String
  destination   String
  departureDate DateTime?
  returnDate    DateTime?
  maxPrice      Float?
  maxMiles      Int?
  airline       String?
  frequency     String   @default("daily") // realtime, daily, weekly
  isActive      Boolean  @default(true)
  lastChecked   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications AlertNotification[]

  @@map("flight_alerts")
}

model AlertNotification {
  id          String   @id @default(cuid())
  alertId     String
  channel     String   // email, whatsapp, push, sms
  title       String
  message     String   @db.Text
  flightData  String?  @db.Text // JSON with flight details
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())

  alert FlightAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@map("alert_notifications")
}

// ==================== BUSCA DE VOOS ====================

model FlightSearch {
  id            String   @id @default(cuid())
  userId        String?
  origin        String
  destination   String
  departureDate DateTime
  returnDate    DateTime?
  passengers    Int      @default(1)
  cabinClass    String   @default("economy") // economy, business, first
  results       String?  @db.Text // JSON cached results
  createdAt     DateTime @default(now())

  @@map("flight_searches")
}

model SavedFlight {
  id          String   @id @default(cuid())
  userId      String
  origin      String
  destination String
  airline     String
  price       Float
  miles       Int?
  vpm         Float?   // valor por milha
  departureAt DateTime
  returnAt    DateTime?
  flightData  String?  @db.Text // full JSON
  createdAt   DateTime @default(now())

  @@map("saved_flights")
}

model PriceHistory {
  id          String   @id @default(cuid())
  origin      String
  destination String
  airline     String?
  price       Float
  miles       Int?
  cabinClass  String   @default("economy")
  recordedAt  DateTime @default(now())

  @@index([origin, destination, recordedAt])
  @@map("price_history")
}

// ==================== MARKETPLACE DE MILHAS ====================

enum MilesListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

model MilesListing {
  id            String             @id @default(cuid())
  sellerId      String
  program       String             // ex: "LATAM Pass", "Smiles", "TudoAzul"
  amount        Int                // quantidade de milhas
  pricePerThousand Float           // preço por 1000 milhas
  totalPrice    Float
  minPurchase   Int                @default(1000)
  expiresAt     DateTime?
  status        MilesListingStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  seller        User               @relation("MilesListingSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  transactions  MilesTransaction[]

  @@map("miles_listings")
}

model MilesTransaction {
  id          String   @id @default(cuid())
  listingId   String
  buyerId     String
  sellerId    String
  amount      Int      // miles amount
  totalPrice  Float
  platformFee Float    // 5% fee
  sellerPayout Float
  status      String   @default("pending") // pending, escrow, completed, disputed, refunded
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing MilesListing @relation(fields: [listingId], references: [id])

  @@map("miles_transactions")
}

// ==================== PROGRAMA DE AFILIADOS ====================

model AffiliateLink {
  id          String   @id @default(cuid())
  userId      String
  name        String
  url         String
  code        String   @unique
  commission  Float    @default(0) // percentage
  category    String?  // credit-card, miles-sale, course, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks      AffiliateClick[]

  @@map("affiliate_links")
}

model AffiliateClick {
  id          String   @id @default(cuid())
  linkId      String
  ip          String?
  userAgent   String?
  referrer    String?
  converted   Boolean  @default(false)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  link AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("affiliate_clicks")
}

model AffiliateEarning {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   // click, sale, referral
  description String
  status      String   @default("pending") // pending, approved, paid
  createdAt   DateTime @default(now())

  @@map("affiliate_earnings")
}

// ==================== MONITOR DE MILHAS DO USUARIO ====================

model UserMilesAccount {
  id          String    @id @default(cuid())
  userId      String
  program     String    // LATAM Pass, Smiles, TudoAzul, etc.
  balance     Int       @default(0)
  expiresAt   DateTime?
  lastUpdated DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, program])
  @@map("user_miles_accounts")
}

// ==================== NEWSLETTER ====================

model Newsletter {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  isPremium   Boolean  @default(false)
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("newsletters")
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  userId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("newsletter_subscribers")
}
